// ============================================================
// GutSync — Prisma Schema
// Phase 1 (MVP) + Phase 2 (Coach Marketplace)
// Database: PostgreSQL via Supabase
// ============================================================

enum SubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum SubscriptionTier {
  FREE
  PREMIUM_MONTHLY
  PREMIUM_ANNUAL
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  DRINK
}

enum Symptom {
  BLOATING
  CRAMPING
  NAUSEA
  FATIGUE
  BRAIN_FOG
  URGENCY
  CONSTIPATION
  HEARTBURN
  DIARRHEA
  GAS
  REFLUX
  STOMACH_PAIN
}

enum Mood {
  GREAT
  GOOD
  NEUTRAL
  LOW
  TERRIBLE
}

enum TimeOfDay {
  MORNING
  AFTERNOON
  EVENING
}

enum InsightType {
  TRIGGER_FOOD
  WEEKLY_SUMMARY
  PATTERN_DETECTED
  SAFE_FOOD
}

enum ProgramType {
  LOW_FODMAP
  GLUTEN_FREE
  DAIRY_FREE
  NIGHTSHADE_FREE
  ELIMINATION_BASIC
}

enum ProgramStatus {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  COMPLETED
  ABANDONED
}

enum ReportType {
  DAYS_30
  DAYS_60
  DAYS_90
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum CoachDocumentType {
  CERTIFICATION
  OFFER_LETTER
  EXPERIENCE_LETTER
  DEGREE
  REGISTRATION
  OTHER
}

enum ClientStatus {
  ACTIVE
  ENDED
  BLOCKED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
  REFUNDED
}

enum DataShareScope {
  MEAL_LOGS
  SYMPTOM_LOGS
  ENERGY_LOGS
  AI_INSIGHTS
  HEALTH_REPORTS
}

// ============================================================
// PHASE 1 — CORE USER & AUTH (Better Auth)
// Better Auth owns: User, Session, Account, Verification
// Run `npx better-auth generate` to sync if you add plugins
// Docs: https://www.better-auth.com/docs/integrations/prisma
// ============================================================

// Better Auth — User
// Core fields are required by Better Auth. All GutSync-specific
// fields are added here as extensions via the Prisma adapter.
model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  // Better Auth — Two user roles: "user" (default) or "coach"
  // Set to "coach" when CoachProfile is created and approved
  role String @default("user")

  // Stripe
  subscriptionStatus SubscriptionStatus @default(FREE)
  subscriptionTier   SubscriptionTier   @default(FREE)
  stripeCustomerId   String?            @unique
  trialEndsAt        DateTime?

  // Onboarding
  onboardingComplete Boolean  @default(false)
  conditions         String[] // e.g. ["IBS", "SIBO", "Crohn's"]
  dietaryGoals       String[] // e.g. ["Identify triggers", "Reduce bloating"]
  timezone           String   @default("UTC")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // Phase 1 relations
  mealEntries   MealEntry[]
  symptomLogs   SymptomLog[]
  energyLogs    EnergyLog[]
  aiInsights    AIInsight[]
  programs      UserProgram[]
  healthReports HealthReport[]
  pushTokens    PushToken[]

  // Phase 2 relations
  coachProfile   CoachProfile?
  coachClients   CoachClient[]  @relation("ClientUser")
  bookedSessions CoachSession[] @relation("SessionUser")
  reviewsGiven   CoachReview[]  @relation("ReviewAuthor")

  @@index([email])
  @@index([stripeCustomerId])
  @@index([role])
  @@map("user")
}

// Better Auth — Session
// expiresAt replaces NextAuth's expires.
// token is the session token (replaces sessionToken).
// ipAddress + userAgent stored for security audit.
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("session")
}

// Better Auth — Account
// Replaces NextAuth Account. Supports OAuth + credential providers.
// password field is used for email/password auth (hashed by Better Auth).
model Account {
  id                    String    @id
  accountId             String // Provider's user ID
  providerId            String // e.g. "google", "github", "credential"
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // Hashed — used for credential provider only
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

// Better Auth — Verification
// Replaces NextAuth VerificationToken.
// Used for email verification, magic links, password reset.
model Verification {
  id         String   @id
  identifier String // Email or phone
  value      String // The token/OTP value
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Push notification tokens (web-push)
// Unchanged — not part of auth layer
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// PHASE 1 — MEAL LOGGING
// ============================================================

model MealEntry {
  id       String   @id @default(cuid())
  userId   String
  mealType MealType
  loggedAt DateTime @default(now())
  notes    String?
  photoUrl String?

  // Foods stored as JSON array of FoodItem objects
  // { usdaId, name, portion, unit, calories?, carbs?, fat?, protein? }
  foods Json[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptomLogs SymptomLog[]

  @@index([userId])
  @@index([userId, loggedAt])
}

// ============================================================
// PHASE 1 — SYMPTOM LOGGING
// ============================================================

model SymptomLog {
  id          String  @id @default(cuid())
  userId      String
  mealEntryId String? // Optional — symptom may not be tied to a specific meal

  symptoms         Symptom[]
  severity         Int // 1–10 overall severity
  minutesAfterMeal Int? // 30, 60, 120, 180, etc.
  notes            String?
  loggedAt         DateTime  @default(now())

  // Per-symptom severity breakdown
  // { symptom: Symptom, severity: 1-10 }
  symptomBreakdown Json[]

  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealEntry MealEntry? @relation(fields: [mealEntryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, loggedAt])
  @@index([mealEntryId])
}

// ============================================================
// PHASE 1 — ENERGY & MOOD LOGGING
// ============================================================

model EnergyLog {
  id          String    @id @default(cuid())
  userId      String
  energyLevel Int // 1–10
  mood        Mood
  timeOfDay   TimeOfDay
  notes       String?
  loggedAt    DateTime  @default(now())

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timeOfDay, loggedAt]) // Prevent duplicate check-ins per slot per day
  @@index([userId])
  @@index([userId, loggedAt])
}

// ============================================================
// PHASE 1 — AI INSIGHTS
// ============================================================

model AIInsight {
  id     String      @id @default(cuid())
  userId String
  type   InsightType

  // Trigger food insight fields
  suspectedFoods Json[] // { foodName, confidence (0-100), occurrences, symptomCorrelations }

  // Summary text rendered in UI
  summary        String  @db.Text
  detailMarkdown String? @db.Text // Longer explanation for expanded view

  // Metadata
  dataRangeStart DateTime // What date range was analysed
  dataRangeEnd   DateTime
  generatedAt    DateTime  @default(now())
  readAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, generatedAt])
}

// ============================================================
// PHASE 1 — ELIMINATION DIET PROGRAMS
// ============================================================

model UserProgram {
  id          String        @id @default(cuid())
  userId      String
  programType ProgramType
  status      ProgramStatus @default(NOT_STARTED)

  startedAt   DateTime?
  completedAt DateTime?
  currentDay  Int       @default(0)

  // JSON progress blob — stores reintroduction phase data, notes, etc.
  progress Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks ProgramTask[]

  @@unique([userId, programType]) // One active program per type per user
  @@index([userId])
}

model ProgramTask {
  id          String  @id @default(cuid())
  programId   String
  day         Int // Day number in the program (1–42 for 6-week)
  title       String
  description String  @db.Text
  category    String? // e.g. "meal", "reintroduce", "education", "reflection"

  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String? // User notes on task completion

  program UserProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, day, title])
  @@index([programId])
}

// ============================================================
// PHASE 1 — HEALTH REPORTS
// ============================================================

model HealthReport {
  id         String     @id @default(cuid())
  userId     String
  reportType ReportType
  fileUrl    String // Supabase Storage URL
  fileSize   Int? // bytes

  // Snapshot of data included in report
  dataSnapshot Json // summary stats embedded for quick display

  generatedAt DateTime  @default(now())
  expiresAt   DateTime? // Optional expiry for storage management

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// PHASE 1 — STRIPE SUBSCRIPTIONS
// ============================================================

model StripeSubscription {
  id                   String             @id @default(cuid())
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  stripePriceId        String
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeCustomerId])
}

// ============================================================
// PHASE 2 — COACH PROFILES
// ============================================================

model CoachProfile {
  id     String @id @default(cuid())
  userId String @unique // 1:1 with User

  // Profile content
  headline        String // e.g. "IBS & Low-FODMAP Specialist"
  bio             String   @db.Text
  specialisations String[] // e.g. ["IBS", "SIBO", "Weight Management", "Microbiome"]
  languages       String[] @default(["English"])
  sessionRate     Decimal  @db.Decimal(10, 2) // USD per session

  // Scheduling (Cal.com or Calendly link)
  calLink     String? // e.g. https://cal.com/drjane or Calendly link
  calProvider String? @default("cal.com") // "cal.com" | "calendly"

  // Verification
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  rejectionReason    String?

  // Stripe Connect
  stripeAccountId          String? @unique // Stripe Connect Express account ID
  stripeOnboardingComplete Boolean @default(false)
  payoutsEnabled           Boolean @default(false)

  // Listing features
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?
  isActive      Boolean   @default(true)

  // Coach subscription (Coach Pro)
  coachSubscriptionStatus SubscriptionStatus @default(FREE)
  coachStripeCustomerId   String?
  coachStripePriceId      String?

  // Stats (denormalised for performance)
  totalSessions Int     @default(0)
  averageRating Decimal @default(0) @db.Decimal(3, 2)
  reviewCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents CoachDocument[]
  clients   CoachClient[]
  sessions  CoachSession[]
  reviews   CoachReview[]

  @@index([verificationStatus])
  @@index([isActive, isFeatured])
  @@index([specialisations])
}

// ============================================================
// PHASE 2 — COACH CERTIFICATION DOCUMENTS
// ============================================================

model CoachDocument {
  id             String            @id @default(cuid())
  coachProfileId String
  documentType   CoachDocumentType
  fileName       String
  fileUrl        String // Supabase Storage URL (private bucket)
  fileSize       Int? // bytes
  mimeType       String?

  // Review
  reviewedAt DateTime?
  reviewedBy String? // Admin user ID
  reviewNote String?

  uploadedAt DateTime @default(now())

  coachProfile CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  @@index([coachProfileId])
}

// ============================================================
// PHASE 2 — COACH <-> CLIENT RELATIONSHIP
// ============================================================

model CoachClient {
  id             String       @id @default(cuid())
  coachProfileId String
  userId         String // The GutSync user (client)
  status         ClientStatus @default(ACTIVE)

  // Granular data share consent
  sharedScopes DataShareScope[] // Which data the user has consented to share

  sharedAt  DateTime  @default(now())
  endedAt   DateTime?
  endReason String?

  coachProfile CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  user         User         @relation("ClientUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coachProfileId, userId])
  @@index([coachProfileId])
  @@index([userId])
}

// ============================================================
// PHASE 2 — SESSIONS (BOOKINGS)
// ============================================================

model CoachSession {
  id             String @id @default(cuid())
  coachProfileId String
  userId         String // The client

  status       SessionStatus @default(SCHEDULED)
  scheduledAt  DateTime
  durationMins Int           @default(30)

  // Financials
  sessionFee  Decimal @db.Decimal(10, 2) // Total charged to user
  platformFee Decimal @db.Decimal(10, 2) // 20% retained by GutSync
  coachPayout Decimal @db.Decimal(10, 2) // 80% transferred to coach

  // Stripe
  stripePaymentIntentId String? @unique
  stripeTransferId      String? // Transfer to coach account

  // Scheduling tool reference
  calEventId  String? // Cal.com / Calendly event ID (for webhook matching)
  calEventUrl String? // Link to the event

  // Session notes (coach only, not visible to user)
  coachNotes String? @db.Text

  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coachProfile CoachProfile @relation(fields: [coachProfileId], references: [id])
  user         User         @relation("SessionUser", fields: [userId], references: [id])
  review       CoachReview?

  @@index([coachProfileId])
  @@index([userId])
  @@index([scheduledAt])
  @@index([stripePaymentIntentId])
}

// ============================================================
// PHASE 2 — COACH REVIEWS
// ============================================================

model CoachReview {
  id             String @id @default(cuid())
  sessionId      String @unique // One review per session
  coachProfileId String
  userId         String // Reviewer

  rating     Int // 1–5
  reviewText String? @db.Text
  isPublic   Boolean @default(true)

  // Moderation
  flagged    Boolean @default(false)
  flagReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session      CoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  coachProfile CoachProfile @relation(fields: [coachProfileId], references: [id])
  user         User         @relation("ReviewAuthor", fields: [userId], references: [id])

  @@index([coachProfileId])
  @@index([userId])
}

// ============================================================
// PHASE 2 — COACH STRIPE SUBSCRIPTIONS (Coach Pro)
// ============================================================

model CoachStripeSubscription {
  id                   String             @id @default(cuid())
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  stripePriceId        String
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeCustomerId])
}
